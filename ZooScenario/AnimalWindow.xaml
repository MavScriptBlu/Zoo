<Window x:Class="ZooScenario.AnimalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create/Edit Animal" Height="320" Width="400"
        WindowStartupLocation="CenterOwner"
        Loaded="window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Inner form grid -->
        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="4" />
                <RowDefinition Height="30" />
                <RowDefinition Height="4" />
                <RowDefinition Height="30" />
                <RowDefinition Height="4" />
                <RowDefinition Height="30" />
                <RowDefinition Height="4" />
                <RowDefinition Height="30" />
                <RowDefinition Height="4" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <!-- Name -->
            <Label Grid.Row="1" Grid.Column="0" Content="Name" HorizontalAlignment="Right" VerticalAlignment="Center" />
            <TextBox x:Name="nameTextBox" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" LostFocus="nameTextBox_LostFocus" />

            <!-- Gender -->
            <Label Grid.Row="3" Grid.Column="0" Content="Gender" HorizontalAlignment="Right" VerticalAlignment="Center" />
            <ComboBox x:Name="genderComboBox" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" SelectionChanged="genderComboBox_SelectionChanged" />

            <!-- Age -->
            <Label Grid.Row="5" Grid.Column="0" Content="Age" HorizontalAlignment="Right" VerticalAlignment="Center" />
            <TextBox x:Name="ageTextBox" Grid.Row="5" Grid.Column="2" VerticalAlignment="Center" LostFocus="ageTextBox_LostFocus" />

            <!-- Weight -->
            <Label Grid.Row="7" Grid.Column="0" Content="Weight" HorizontalAlignment="Right" VerticalAlignment="Center" />
            <TextBox x:Name="weightTextBox" Grid.Row="7" Grid.Column="2" VerticalAlignment="Center" LostFocus="weightTextBox_LostFocus" />

            <!-- Is Pregnant -->
            <Label Grid.Row="9" Grid.Column="0" Content="Is Pregnant" HorizontalAlignment="Right" VerticalAlignment="Center" />
            <StackPanel Grid.Row="9" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Label x:Name="pregnancyStatusLabel" Content="No" VerticalAlignment="Center" Padding="0,0,6,0" />
                <Button x:Name="makePregnantButton" Content="Make pregnant" VerticalAlignment="Center" Click="makePregnantButton_Click" />
            </StackPanel>
        </Grid>

        <!-- OK and Cancel buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button x:Name="okButton" Content="OK" Width="80" Height="25" IsDefault="True" Click="okButton_Click" Margin="0,0,5,0" />
            <Button x:Name="cancelButton" Content="Cancel" Width="80" Height="25" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
