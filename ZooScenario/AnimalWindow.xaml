<Window x:Class="ZooScenario.AnimalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Loaded="window_Loaded"
        Title="Animal" Height="320" Width="400" WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="4"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Content="Name:" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        <TextBox x:Name="nameTextBox" Grid.Column="2" Grid.Row="1" VerticalAlignment="Center" LostFocus="nameTextBox_LostFocus"/>

        <Label Content="Age:" Grid.Column="0" Grid.Row="3" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        <TextBox x:Name="ageTextBox" Grid.Column="2" Grid.Row="3" VerticalAlignment="Center" LostFocus="ageTextBox_LostFocus"/>

        <Label Content="Gender:" Grid.Column="0" Grid.Row="5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        <ComboBox x:Name="genderComboBox" Grid.Column="2" Grid.Row="5" VerticalAlignment="Center" SelectionChanged="genderComboBox_SelectionChanged"/>

        <Label Content="Weight:" Grid.Column="0" Grid.Row="7" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        <TextBox x:Name="weightTextBox" Grid.Column="2" Grid.Row="7" VerticalAlignment="Center" LostFocus="weightTextBox_LostFocus"/>

        <Label Content="Is Pregnant:" Grid.Column="0" Grid.Row="9" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        <StackPanel Grid.Column="2" Grid.Row="9" Orientation="Horizontal">
            <Label x:Name="pregnanceStatusLabel" Content="No" VerticalAlignment="Center"/>
            <Button x:Name="makePregnantButton" Content="Make Pregnant" VerticalAlignment="Center" Click="makePregnantButton_Click"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,4">
            <Button x:Name="okButton" Content="OK" Width="75" Height="23" IsDefault="True" Click="okButton_Click" Margin="0,0,4,0"/>
            <Button x:Name="cancelButton" Content="Cancel" Width="75" Height="23" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
