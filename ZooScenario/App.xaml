<Application x:Class="ZooScenario.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ZooScenario"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Chimpanzee -->
        <Canvas x:Key="Chimpanzee" Width="100" Height="100">
            <Ellipse Fill="#8B4513" Width="50" Height="50" Canvas.Left="25" Canvas.Top="10"/>
            <Ellipse Fill="#8B4513" Width="60" Height="50" Canvas.Left="20" Canvas.Top="50"/>
            <Ellipse Fill="#D2691E" Width="20" Height="15" Canvas.Left="40" Canvas.Top="30"/>
            <Ellipse Fill="#8B4513" Width="15" Height="30" Canvas.Left="5" Canvas.Top="55"/>
            <Ellipse Fill="#8B4513" Width="15" Height="30" Canvas.Left="80" Canvas.Top="55"/>
        </Canvas>

        <!-- Dingo -->
        <Canvas x:Key="Dingo" Width="100" Height="100">
            <Ellipse Fill="#C8963F" Width="60" Height="40" Canvas.Left="20" Canvas.Top="35"/>
            <Ellipse Fill="#C8963F" Width="35" Height="35" Canvas.Left="10" Canvas.Top="20"/>
            <Ellipse Fill="#C8963F" Width="5" Height="25" Canvas.Left="75" Canvas.Top="25"/>
            <Ellipse Fill="#C8963F" Width="5" Height="25" Canvas.Left="82" Canvas.Top="25"/>
            <Rectangle Fill="#C8963F" Width="10" Height="35" Canvas.Left="85" Canvas.Top="55"/>
        </Canvas>

        <!-- Eagle -->
        <Canvas x:Key="Eagle" Width="100" Height="100">
            <Ellipse Fill="#4A4A4A" Width="30" Height="30" Canvas.Left="35" Canvas.Top="10"/>
            <Ellipse Fill="#4A4A4A" Width="50" Height="35" Canvas.Left="25" Canvas.Top="35"/>
            <Polygon Fill="#4A4A4A" Points="0,60 25,45 25,60"/>
            <Polygon Fill="#4A4A4A" Points="100,60 75,45 75,60"/>
            <Ellipse Fill="White" Width="12" Height="12" Canvas.Left="44" Canvas.Top="14"/>
            <Ellipse Fill="Gold" Width="10" Height="8" Canvas.Left="45" Canvas.Top="30"/>
        </Canvas>

        <!-- Hummingbird -->
        <Canvas x:Key="Hummingbird" Width="100" Height="100">
            <Ellipse Fill="#00AA88" Width="25" Height="20" Canvas.Left="38" Canvas.Top="38"/>
            <Ellipse Fill="#00AA88" Width="15" Height="15" Canvas.Left="43" Canvas.Top="25"/>
            <Polygon Fill="#88DDCC" Points="10,40 38,48 10,55"/>
            <Polygon Fill="#88DDCC" Points="90,40 63,48 90,55"/>
            <Rectangle Fill="#00AA88" Width="3" Height="20" Canvas.Left="49" Canvas.Top="55"/>
        </Canvas>

        <!-- Kangaroo -->
        <Canvas x:Key="Kangaroo" Width="100" Height="100">
            <Ellipse Fill="#C8963F" Width="30" Height="25" Canvas.Left="35" Canvas.Top="10"/>
            <Ellipse Fill="#C8963F" Width="35" Height="50" Canvas.Left="33" Canvas.Top="30"/>
            <Ellipse Fill="#C8963F" Width="10" Height="35" Canvas.Left="20" Canvas.Top="55"/>
            <Ellipse Fill="#C8963F" Width="20" Height="10" Canvas.Left="60" Canvas.Top="75"/>
            <Ellipse Fill="#C8963F" Width="8" Height="40" Canvas.Left="78" Canvas.Top="40"/>
        </Canvas>

        <!-- Ostrich -->
        <Canvas x:Key="Ostrich" Width="100" Height="100">
            <Ellipse Fill="#4A4A4A" Width="30" Height="30" Canvas.Left="35" Canvas.Top="5"/>
            <Ellipse Fill="#4A4A4A" Width="40" Height="50" Canvas.Left="30" Canvas.Top="40"/>
            <Ellipse Fill="Tan" Width="8" Height="30" Canvas.Left="46" Canvas.Top="10"/>
            <Rectangle Fill="#808080" Width="8" Height="35" Canvas.Left="35" Canvas.Top="85"/>
            <Rectangle Fill="#808080" Width="8" Height="35" Canvas.Left="55" Canvas.Top="85"/>
        </Canvas>

        <!-- Platypus -->
        <Canvas x:Key="Platypus" Width="100" Height="100">
            <Ellipse Fill="#8B4513" Width="60" Height="30" Canvas.Left="20" Canvas.Top="35"/>
            <Ellipse Fill="#8B4513" Width="25" Height="20" Canvas.Left="10" Canvas.Top="40"/>
            <Ellipse Fill="#4A8FB5" Width="30" Height="12" Canvas.Left="5" Canvas.Top="43"/>
            <Rectangle Fill="#4A4A4A" Width="15" Height="20" Canvas.Left="72" Canvas.Top="60"/>
        </Canvas>

        <!-- Shark -->
        <Canvas x:Key="Shark" Width="100" Height="100">
            <Ellipse Fill="#4A6FA5" Width="80" Height="35" Canvas.Left="10" Canvas.Top="32"/>
            <Polygon Fill="#4A6FA5" Points="90,50 100,30 100,70"/>
            <Polygon Fill="#4A6FA5" Points="50,32 60,10 70,32"/>
            <Ellipse Fill="White" Width="10" Height="8" Canvas.Left="15" Canvas.Top="44"/>
            <Polygon Fill="White" Points="10,55 20,65 10,65"/>
        </Canvas>

        <!-- Squirrel -->
        <Canvas x:Key="Squirrel" Width="100" Height="100">
            <Ellipse Fill="#808080" Width="30" Height="30" Canvas.Left="35" Canvas.Top="30"/>
            <Ellipse Fill="#808080" Width="35" Height="40" Canvas.Left="33" Canvas.Top="55"/>
            <Ellipse Fill="#A0A0A0" Width="40" Height="30" Canvas.Left="30" Canvas.Top="10"/>
            <Ellipse Fill="#808080" Width="8" Height="8" Canvas.Left="38" Canvas.Top="15"/>
            <Ellipse Fill="#808080" Width="8" Height="8" Canvas.Left="54" Canvas.Top="15"/>
        </Canvas>

        <!-- Guest -->
        <Canvas x:Key="Guest" Width="100" Height="100">
            <Ellipse Fill="PeachPuff" Width="30" Height="30" Canvas.Left="35" Canvas.Top="5"/>
            <Rectangle Fill="CornflowerBlue" Width="30" Height="35" Canvas.Left="35" Canvas.Top="35"/>
            <Rectangle Fill="SandyBrown" Width="12" Height="30" Canvas.Left="25" Canvas.Top="70"/>
            <Rectangle Fill="SandyBrown" Width="12" Height="30" Canvas.Left="63" Canvas.Top="70"/>
            <Rectangle Fill="PeachPuff" Width="10" Height="25" Canvas.Left="20" Canvas.Top="40"/>
            <Rectangle Fill="PeachPuff" Width="10" Height="25" Canvas.Left="70" Canvas.Top="40"/>
        </Canvas>
    </Application.Resources>
</Application>
