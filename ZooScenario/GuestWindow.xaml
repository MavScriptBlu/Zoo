<Window x:Class="ZooScenario.GuestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create/Edit Guest" Height="380" Width="420"
        WindowStartupLocation="CenterOwner"
        Loaded="window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Inner form grid -->
        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="4" />
                <RowDefinition Height="30" />
                <RowDefinition Height="4" />
                <RowDefinition Height="30" />
                <RowDefinition Height="4" />
                <RowDefinition Height="30" />
                <RowDefinition Height="4" />
                <RowDefinition Height="30" />
                <RowDefinition Height="4" />
                <RowDefinition Height="30" />
                <RowDefinition Height="4" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <!-- Name -->
            <Label Grid.Row="1" Grid.Column="0" Content="Name" HorizontalAlignment="Right" VerticalAlignment="Center" />
            <TextBox x:Name="nameTextBox" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" LostFocus="nameTextBox_LostFocus" />

            <!-- Gender -->
            <Label Grid.Row="3" Grid.Column="0" Content="Gender" HorizontalAlignment="Right" VerticalAlignment="Center" />
            <ComboBox x:Name="genderComboBox" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" SelectionChanged="genderComboBox_SelectionChanged" />

            <!-- Age -->
            <Label Grid.Row="5" Grid.Column="0" Content="Age" HorizontalAlignment="Right" VerticalAlignment="Center" />
            <TextBox x:Name="ageTextBox" Grid.Row="5" Grid.Column="2" VerticalAlignment="Center" LostFocus="ageTextBox_LostFocus" />

            <!-- Wallet Color -->
            <Label Grid.Row="7" Grid.Column="0" Content="Wallet color" HorizontalAlignment="Right" VerticalAlignment="Center" />
            <ComboBox x:Name="walletColorComboBox" Grid.Row="7" Grid.Column="2" VerticalAlignment="Center" SelectionChanged="walletColorComboBox_SelectionChanged" />

            <!-- Wallet Money Balance -->
            <Label Grid.Row="9" Grid.Column="0" Content="Money balance" HorizontalAlignment="Right" VerticalAlignment="Center" />
            <StackPanel Grid.Row="9" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="addMoneyButton" Content="+" Width="25" Click="addMoneyButton_Click" />
                <ComboBox x:Name="moneyAmountComboBox" Width="55" Margin="4,0" />
                <Button x:Name="subtractMoneyButton" Content="-" Width="25" Click="subtractMoneyButton_Click" />
                <Label x:Name="moneyBalanceLabel" Content="$0.00" VerticalAlignment="Center" Margin="4,0,0,0" />
            </StackPanel>

            <!-- Checking Account Balance -->
            <Label Grid.Row="11" Grid.Column="0" Content="Account balance" HorizontalAlignment="Right" VerticalAlignment="Center" />
            <StackPanel Grid.Row="11" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="addAccountButton" Content="+" Width="25" Click="addAccountButton_Click" />
                <ComboBox x:Name="accountComboBox" Width="55" Margin="4,0" />
                <Button x:Name="subtractAccountButton" Content="-" Width="25" Click="subtractAccountButton_Click" />
                <Label x:Name="accountBalanceLabel" Content="$0.00" VerticalAlignment="Center" Margin="4,0,0,0" />
            </StackPanel>
        </Grid>

        <!-- OK and Cancel buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button x:Name="okButton" Content="OK" Width="80" Height="25" IsDefault="True" Click="okButton_Click" Margin="0,0,5,0" />
            <Button x:Name="cancelButton" Content="Cancel" Width="80" Height="25" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
